// electron-builder.json5
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",

  "appId": "com.byrossi.inventario",
  "productName": "Sistema de Gestion",
  "asar": true,

  "directories": {
    "output": "release/${version}"
  },

  "files": [
    "dist",
    "dist-electron"
  ],

  // ✅ Copiar TODO el backend generado (más robusto)
  "extraResources": [
    { "from": "backend", "to": "backend" },
    { "from": "backend.env.ejemplo", "to": "backend.env.ejemplo" }
  ],

  // ✅ Prisma engines fuera de asar (por si alguna vez cae dentro)
  "asarUnpack": [
    "**/backend/node_modules/.prisma/**",
    "**/backend/node_modules/@prisma/engines/**"
  ],

  "mac": {
    "target": ["dmg"],
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}"
  },

  "dmg": {
    "contents": [
      { "x": 140, "y": 220, "type": "file" },
      { "x": 430, "y": 220, "type": "link", "path": "/Applications" },
      { "x": 140, "y": 420, "type": "file", "path": "backend.env.ejemplo" }
    ]
  },

  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },

  "linux": {
    "target": ["AppImage"],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}